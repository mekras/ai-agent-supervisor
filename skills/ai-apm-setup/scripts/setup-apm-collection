#!/usr/bin/env python3
"""Create or update a minimal APM skill collection manifest."""

from __future__ import annotations

import argparse
import re
from pathlib import Path


DEFAULT_TESTS = (
    "python3 tools/validate-trigger-evals.py skills --require-all && "
    "python3 tools/validate-skill-result-evals.py skills && "
    "python3 tools/run-skill-evals.py skills"
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Create or update apm.yml for a skills collection.",
    )
    parser.add_argument(
        "project_root",
        nargs="?",
        default=".",
        type=Path,
        help="Project root. Defaults to the current directory.",
    )
    parser.add_argument(
        "--name",
        help="Package name for a newly created manifest.",
    )
    parser.add_argument(
        "--description",
        default="Skill collection",
        help="Description for a newly created manifest.",
    )
    parser.add_argument(
        "--target",
        action="append",
        help="Target harness for a newly created manifest. May be repeated.",
    )
    parser.add_argument(
        "--test-command",
        help="Command stored in scripts.tests. Auto-detected when omitted.",
    )
    return parser.parse_args()


def detect_test_command(root: Path) -> str | None:
    required = [
        root / "tools" / "validate-trigger-evals.py",
        root / "tools" / "validate-skill-result-evals.py",
        root / "tools" / "run-skill-evals.py",
    ]
    if all(path.is_file() for path in required):
        return DEFAULT_TESTS
    return None


def block_bounds(lines: list[str], key: str) -> tuple[int, int] | None:
    pattern = re.compile(rf"^{re.escape(key)}:\s*(?:#.*)?$")
    for index, line in enumerate(lines):
        if not pattern.match(line):
            continue
        end = index + 1
        while end < len(lines):
            current = lines[end]
            if current and not current.startswith((" ", "-")):
                break
            end += 1
        return index, end
    return None


def yaml_double_quote(value: str) -> str:
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'


def ensure_block(lines: list[str], key: str, block: list[str]) -> list[str]:
    bounds = block_bounds(lines, key)
    if bounds is None:
        if lines and lines[-1].strip():
            lines.append("")
        lines.extend(block)
        return lines
    start, end = bounds
    return lines[:start] + block + lines[end:]


def ensure_target(text: str, targets: list[str]) -> str:
    lines = text.splitlines()
    if block_bounds(lines, "target") is not None:
        return text
    block = ["target:", *(f"  - {target}" for target in targets)]
    return "\n".join(ensure_block(lines, "target", block)).rstrip() + "\n"


def ensure_type(text: str) -> str:
    lines = text.splitlines()
    if block_bounds(lines, "type") is not None:
        return text
    lines = ensure_block(lines, "type", ['type: "skill"'])
    return "\n".join(lines).rstrip() + "\n"


def ensure_dependencies(text: str) -> str:
    lines = text.splitlines()
    bounds = block_bounds(lines, "dependencies")
    if bounds is None:
        block = ["dependencies:", "  apm: []", "  mcp: []"]
        return "\n".join(ensure_block(lines, "dependencies", block)).rstrip() + "\n"

    start, end = bounds
    block = lines[start:end]
    while block and not block[-1].strip():
        block.pop()
    if not any(re.match(r"^  apm:\s*", line) for line in block):
        block.append("  apm: []")
    if not any(re.match(r"^  mcp:\s*", line) for line in block):
        block.append("  mcp: []")
    lines = lines[:start] + block + lines[end:]
    return "\n".join(lines).rstrip() + "\n"


def ensure_script_tests(text: str, command: str) -> str:
    lines = text.splitlines()
    scripts = block_bounds(lines, "scripts")
    scripts_block = ["scripts:", f"  tests: {yaml_double_quote(command)}"]
    if scripts is None:
        return "\n".join(ensure_block(lines, "scripts", scripts_block)).rstrip() + "\n"

    start, end = scripts
    block = lines[start:end]
    for index, line in enumerate(block):
        if re.match(r"^  tests:\s*", line):
            block[index] = f"  tests: {yaml_double_quote(command)}"
            break
    else:
        block.append(f"  tests: {yaml_double_quote(command)}")
    lines = lines[:start] + block + lines[end:]
    return "\n".join(lines).rstrip() + "\n"


def create_manifest(root: Path, args: argparse.Namespace, command: str) -> str:
    name = args.name or root.name
    targets = args.target or ["codex"]
    target_lines = "\n".join(f"  - {target}" for target in targets)
    return (
        f"name: {name}\n"
        "version: 0.1.0\n"
        f'description: "{args.description}"\n'
        "target:\n"
        f"{target_lines}\n"
        'type: "skill"\n'
        "dependencies:\n"
        "  apm: []\n"
        "  mcp: []\n"
        "scripts:\n"
        f"  tests: {yaml_double_quote(command)}\n"
    )


def main() -> int:
    args = parse_args()
    root = args.project_root.resolve()
    manifest = root / "apm.yml"
    command = args.test_command or detect_test_command(root)
    if not command:
        raise SystemExit(
            "No test command detected. Pass --test-command or create collection tests first.",
        )

    if manifest.exists():
        text = ensure_script_tests(manifest.read_text(encoding="utf-8"), command)
        text = ensure_type(text)
        text = ensure_target(text, args.target or ["codex"])
        text = ensure_dependencies(text)
    else:
        text = create_manifest(root, args, command)

    manifest.write_text(text, encoding="utf-8")
    print(f"manifest={manifest}")
    print(f"tests={command}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
