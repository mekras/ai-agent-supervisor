# Локальная конфигурация модельных evals (apm run evals).
#
# Это образец. Раннер при первом запуске копирует его в evals.local.yml и
# добавляет копию в .git/info/exclude, поэтому реальный конфиг в Git не попадает.
# Здесь хранятся только настройки моделей, не секреты: ключи и подписку
# передавайте через переменные окружения вашего адаптера.

# Адаптеры моделей: имя адаптера -> команда. Контракт адаптера:
# <команда> <модель>; запрос на stdin, текст ответа на stdout.
# Готовый пример для Codex CLI лежит в tools/adapters/codex. Под другую модель
# напишите свой адаптер по тому же контракту и добавьте его сюда.
adapters:
  codex: tools/adapters/codex
  # claude: tools/adapters/claude

# Модели для применения навыков в формате адаптер:модель. Каждая запись
# прогоняется отдельно, результаты сопоставимы по одинаковым критериям.
models:
  - codex:gpt-5.3-codex-spark
  # - claude:opus-4.8

# Модель-судья в формате адаптер:модель. Если не задана, берётся первая из models.
judge: codex:gpt-5.5

# Тайм-аут одного вызова адаптера в секундах.
timeout: 900
