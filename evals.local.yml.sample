# Локальная конфигурация модельных evals (apm run evals).
#
# Это образец. При первом запуске evals он будет скопирован в evals.local.yml.

# Адаптеры моделей: имя адаптера -> команда. Контракт адаптера:
# <команда> <модель>; запрос на stdin, текст ответа на stdout.
adapters:
#  codex: tools/adapters/codex
#  claude: tools/adapters/claude

# Модели для применения навыков в формате адаптер:модель. Каждая запись
# прогоняется отдельно, результаты сопоставимы по одинаковым критериям.
# Здесь держите слабые модели: прогон должен проверять навык на слабом звене.
models:
  - adapter:sample-model
#  - another-adapter:sample-model

# Модели, которым разрешена рабочая копия fixture. Только такие адаптеры должны
# запускать агента в APM_EVAL_WORKSPACE и сохранять сделанные изменения.
workspace_models: []

# Модель-судья в формате адаптер:модель.
# Задавать обязательно. Назначайте сильную модель.
judge: adapter:judge-model

# Тайм-аут одного вызова адаптера в секундах.
timeout: 900

# Каждый режим (baseline, skill, catalog) повторяется столько раз. Повторы
# нужны, чтобы не принять единичный удачный ответ за эффект навыка.
repetitions: 3
# Число независимых вердиктов судьи; итог требует большинства.
judge_repetitions: 3
results_dir: eval-results

# Необязательная оценка стоимости; ставки — за миллион оценочных токенов.
# pricing:
#   adapter:sample-model:
#     input_per_million: 0
#     output_per_million: 0
