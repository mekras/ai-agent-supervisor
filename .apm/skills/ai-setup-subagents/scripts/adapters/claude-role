#!/usr/bin/env python3
"""Запустить ограниченный класс исполнения Claude с явной моделью."""

from __future__ import annotations

import json
import os
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any


READ_ONLY_TOOLS = "Read,Glob,Grep"


def response_details(output: str) -> tuple[str | None, object, str, str | None]:
    events: list[dict[str, Any]] = []
    for line in output.splitlines():
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(event, dict):
            events.append(event)

    model = next(
        (
            event["message"]["model"]
            for event in reversed(events)
            if event.get("type") == "assistant"
            and isinstance(event.get("message"), dict)
            and isinstance(event["message"].get("model"), str)
        ),
        None,
    )
    if model is None:
        model = next(
            (
                event["model"]
                for event in events
                if event.get("type") == "system" and isinstance(event.get("model"), str)
            ),
            None,
        )
    notice = next(
        (
            event["content"]
            for event in events
            if event.get("type") == "system"
            and event.get("subtype") == "informational"
            and isinstance(event.get("content"), str)
            and "Model" in event["content"]
        ),
        None,
    )
    result = next(
        (event for event in reversed(events) if event.get("type") == "result"), {}
    )
    usage = result.get("usage") if isinstance(result, dict) else None
    text = result.get("result") if isinstance(result, dict) else None
    return model, usage, text if isinstance(text, str) else "", notice


def main() -> int:
    if len(sys.argv) != 4:
        raise SystemExit("Использование: claude-role <модель> <усилие> <режим>")
    model, effort, sandbox = sys.argv[1:]
    if sandbox != "read-only":
        raise SystemExit("Адаптер Claude поддерживает только режим read-only")
    try:
        request = json.loads(sys.stdin.read())
    except json.JSONDecodeError as error:
        raise SystemExit(f"Не удалось прочитать задачу класса: {error}") from error
    if not isinstance(request, dict):
        raise SystemExit("Задача класса должна быть объектом JSON")
    inputs = request.get("inputs", [])
    if not isinstance(inputs, list) or not all(isinstance(item, str) for item in inputs):
        raise SystemExit("Поле inputs должно быть массивом путей")

    with tempfile.TemporaryDirectory() as workdir:
        command = [
            "claude",
            "--print",
            "--strict-mcp-config",
            "--no-session-persistence",
            "--output-format",
            "stream-json",
            "--verbose",
            "--model",
            model,
            "--effort",
            effort,
            "--tools",
            READ_ONLY_TOOLS,
        ]
        for parent in dict.fromkeys(str(Path(item).resolve().parent) for item in inputs):
            command.extend(["--add-dir", parent])
        completed = subprocess.run(
            command,
            input=json.dumps(request, ensure_ascii=False),
            text=True,
            capture_output=True,
            cwd=workdir,
            check=False,
        )

    actual, usage, result, notice = response_details(completed.stdout)
    raw_log = os.environ.get("CLAUDE_ROLE_LOG")
    if raw_log:
        Path(raw_log).write_text(completed.stdout, encoding="utf-8")
    header = {
        "model": actual if completed.returncode == 0 else None,
        "usage": usage,
        "model_notice": notice,
    }
    print(json.dumps(header, ensure_ascii=False))
    if result:
        print(result)
    elif completed.stdout:
        print(completed.stdout, end="")
    if completed.stderr:
        print(completed.stderr, file=sys.stderr, end="")
    return completed.returncode


if __name__ == "__main__":
    raise SystemExit(main())
