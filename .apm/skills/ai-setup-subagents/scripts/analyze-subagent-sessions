#!/usr/bin/env python3
"""Анализировать JSONL-сессии Codex без вывода их содержимого."""
from __future__ import annotations

import argparse, json
from collections import Counter
from datetime import datetime
from pathlib import Path

def records(path: Path):
    try:
        for line in path.read_text(encoding="utf-8").splitlines():
            try: yield json.loads(line)
            except json.JSONDecodeError: continue
    except OSError: return

def value(event, *keys):
    data = event
    for key in keys:
        if not isinstance(data, dict): return None
        data = data.get(key)
    return data

def analyze(path: Path, cwd: str):
    events = list(records(path)); meta = next((e for e in events if e.get("type") == "session_meta"), {})
    session_cwd = value(meta, "payload", "cwd") or value(meta, "payload", "source", "cwd")
    if session_cwd != cwd: return None
    spawn = value(meta, "payload", "source", "subagent", "thread_spawn") or {}
    child = bool(spawn)
    turns = [e for e in events if e.get("type") == "event_msg" and value(e, "payload", "type") == "task_complete"]
    contexts = [e for e in events if e.get("type") == "turn_context"]
    tools = sum(1 for e in events if e.get("type") in {"response_item", "function_call"} or value(e, "payload", "type") == "function_call")
    changes = sum(1 for e in events if value(e, "payload", "type") in {"patch_applied", "patch_apply_end", "file_change"} or value(e, "payload", "name") == "apply_patch")
    tokens = 0
    for e in events:
        usage = value(e, "payload", "info", "total_token_usage") or value(e, "usage") or {}
        tokens = max(tokens, usage.get("total_tokens", 0) or 0)
    model = next((value(e, "payload", "model") for e in reversed(contexts) if value(e, "payload", "model")), None)
    return {"child": child, "turns": len(turns), "tools": tools, "changes": changes, "tokens": tokens,
            "model": model, "agent_path": spawn.get("agent_path"), "role": spawn.get("agent_role"),
            "date": "/".join(path.parts[-4:-1]) if len(path.parts) > 4 else "unknown"}

def main():
    parser = argparse.ArgumentParser(description="Сводка сессий без текстов запросов")
    parser.add_argument("--sessions", type=Path, required=True); parser.add_argument("--cwd", required=True)
    parser.add_argument("--min-sessions", type=int, default=10); parser.add_argument("--min-turns", type=int, default=30)
    parser.add_argument("--min-days", type=int, default=2); parser.add_argument("--json", action="store_true")
    args = parser.parse_args(); rows = [x for p in args.sessions.rglob("*.jsonl") if (x := analyze(p, args.cwd))]
    parents = [x for x in rows if not x["child"]]; models = [x for x in parents if x["model"]]
    result = {"project": args.cwd, "privacy": "texts, paths outside project and contents are omitted",
      "parent_sessions": len(parents), "completed_turns": sum(x["turns"] for x in parents),
      "days": len(set(x["date"] for x in parents)), "model_coverage": len(models) / len(parents) if parents else 0,
      "tokens": sum(x["tokens"] for x in parents), "tool_calls": sum(x["tools"] for x in parents),
      "file_change_sessions": sum(bool(x["changes"]) for x in parents),
      "task_classes": {"read_only": sum(not x["changes"] for x in parents), "writes": sum(bool(x["changes"]) for x in parents)},
      "child_runs": len(rows) - len(parents),
      "child_model_inheritance_signals": sum(bool(x["child"] and x["agent_path"] is None) for x in rows),
      "history_sufficient": len(parents) >= args.min_sessions and sum(x["turns"] for x in parents) >= args.min_turns and len(set(x["date"] for x in parents)) >= args.min_days and (len(models) / len(parents) if parents else 0) >= .5}
    print(json.dumps(result, ensure_ascii=False, indent=2))

if __name__ == "__main__": main()
